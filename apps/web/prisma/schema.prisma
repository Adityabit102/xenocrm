datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

model Customer {
  id                 String              @id @default(cuid())
  externalId         String?             @unique
  firstName          String
  lastName           String
  phone              String?
  email              String?
  city               String?
  gender             String?
  tier               String?
  rfmRecency         Float?
  rfmFrequency       Float?
  rfmMonetary        Float?
  rfmTier            String?
  marketingConsent   Boolean             @default(true)
  optOutAt           DateTime?
  clvScore           Float? // predicted lifetime value (INR)
  churnScore         Float? // 0..100 churn propensity
  createdAt          DateTime            @default(now())
  orders             Order[]
  communications     CommunicationLog[]
  segmentMemberships SegmentMembership[]
  journeyEnrollments JourneyEnrollment[]
  events             Event[]
  inboundMessages    InboundMessage[]
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model InboundMessage {
  id          String    @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  channel     String // whatsapp | sms | email | rcs
  fromAddress String? // phone or email the reply came from
  body        String
  handled     Boolean   @default(false)
  isStop      Boolean   @default(false) // recognised opt-out (STOP/UNSUBSCRIBE)
  createdAt   DateTime  @default(now())

  @@index([createdAt])
}

model Event {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  externalId String? // storefront/customer id when not yet resolved
  type       String // product_viewed | cart_created | cart_updated | checkout_started | cart_abandoned
  value      Float? // cart / product value
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([type, createdAt])
  @@index([customerId])
}

model Journey {
  id          String              @id @default(cuid())
  name        String
  description String?
  status      String              @default("draft") // draft | active | paused
  triggerType String              @default("manual") // manual | segment | event
  segmentId   String? // enrollment source for manual/segment triggers
  eventType   String? // cart_abandoned | first_purchase | churn_risk (event trigger)
  sentCount   Int                 @default(0)
  steps       JourneyStep[]
  enrollments JourneyEnrollment[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model JourneyStep {
  id        String  @id @default(cuid())
  journeyId String
  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  order     Int
  type      String // message | wait
  channel   String? // message: whatsapp | sms | email | rcs
  template  String? // message body
  waitHours Int? // wait: delay before next step
}

model JourneyEnrollment {
  id          String    @id @default(cuid())
  journeyId   String
  journey     Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  currentStep Int       @default(0)
  status      String    @default("active") // active | completed | exited
  nextRunAt   DateTime?
  enrolledAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([journeyId, customerId])
}

model Order {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderDate   DateTime
  amountInr   Float
  category    String?
  channel     String?
  status      String?
  createdAt   DateTime @default(now())
}

model Segment {
  id                   String              @id @default(cuid())
  name                 String
  description          String?
  filterRules          Json
  naturalLanguageQuery String?
  createdByAi          Boolean             @default(false)
  customerCount        Int                 @default(0)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  campaigns            Campaign[]
  memberships          SegmentMembership[]
}

model SegmentMembership {
  id         String   @id @default(cuid())
  segmentId  String
  segment    Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([segmentId, customerId])
}

model Campaign {
  id                  String             @id @default(cuid())
  name                String
  segmentId           String
  segment             Segment            @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  channel             String
  messageTemplate     String
  status              String             @default("draft")
  scheduledAt         DateTime?
  holdoutPct          Int                @default(0) // % of audience withheld as control
  approvalStatus      String             @default("approved") // approved | pending | rejected
  approvedBy          String?
  approvedAt          DateTime?
  createdByAgent      Boolean            @default(false)
  agentReasoningTrace Json?
  createdAt           DateTime           @default(now())
  stats               CampaignStats?
  communications      CommunicationLog[]
}

model CommunicationLog {
  id              String    @id @default(cuid())
  campaignId      String
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel         String
  renderedMessage String
  status          String    @default("queued")
  failureReason   String?
  queuedAt        DateTime  @default(now())
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  readAt          DateTime?
  clickedAt       DateTime?
  orderPlacedAt   DateTime?
  eventId         String?   @unique
}

model CampaignStats {
  id                    String   @id @default(cuid())
  campaignId            String   @unique
  campaign              Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalSent             Int      @default(0)
  totalDelivered        Int      @default(0)
  totalFailed           Int      @default(0)
  totalOpened           Int      @default(0)
  totalRead             Int      @default(0)
  totalClicked          Int      @default(0)
  totalOrdersAttributed Int      @default(0)
  attributedRevenueInr  Float    @default(0)
  lastUpdated           DateTime @default(now()) @updatedAt
}
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin") // admin | marketer | viewer
  createdAt DateTime @default(now())
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  channel   String // whatsapp | sms | email | rcs
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  detail     String?
  createdAt  DateTime @default(now())
}
